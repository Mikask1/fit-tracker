{
  "id": "/",
  "name": "FitTrack - Fitness Tracking App",
  "short_name": "FitTrack",
  "description": "Track workouts, log exercises, and monitor your fitness progress. Offline-first fitness tracking app with workout routines, calendar, and progress analytics.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait-primary",
  "lang": "en-US",
  "dir": "ltr",
  "background_color": "#ffffff",
  "theme_color": "#3b82f6",
  "categories": ["health", "fitness", "sports", "lifestyle"],
  "icons": [
    {
      "src": "/icons/favicon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/web-app-manifest-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Workout",
      "short_name": "Workout",
      "description": "Begin a new workout session",
      "url": "/timer?source=shortcut",
      "icons": [
        {
          "src": "/icons/favicon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "View Calendar",
      "short_name": "Calendar",
      "description": "See your workout history",
      "url": "/calendar?source=shortcut",
      "icons": [
        {
          "src": "/icons/favicon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Browse Exercises",
      "short_name": "Exercises",
      "description": "View your exercise library",
      "url": "/movements?source=shortcut",
      "icons": [
        {
          "src": "/icons/favicon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Routines",
      "short_name": "Routines",
      "description": "Access your workout routines",
      "url": "/routines?source=shortcut",
      "icons": [
        {
          "src": "/icons/favicon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/movements?source=share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
